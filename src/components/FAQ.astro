---
interface QA { q: string; a: string; }
interface Props { items: QA[]; heading?: string; }
const { items, heading = 'Frequently asked questions' } = Astro.props;
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((i) => ({
    '@type': 'Question', name: i.q,
    acceptedAnswer: { '@type': 'Answer', text: i.a },
  })),
};
---
<section class="mt-10">
  <h2 class="text-2xl font-bold mb-4">{heading}</h2>
  <div class="divide-y divide-[var(--color-line)] border-y border-[var(--color-line)]">
    {items.map((i) => (
      <details class="py-3 group">
        <summary class="cursor-pointer font-medium text-[var(--color-ink)]">{i.q}</summary>
        <p class="mt-2 text-[var(--color-muted)] leading-relaxed" set:html={i.a} />
      </details>
    ))}
  </div>
</section>
<script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
