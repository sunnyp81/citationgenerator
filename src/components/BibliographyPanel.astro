---
// localStorage bibliography list with export. Collapsed by default.
---
<details data-bib-panel class="rounded-xl border border-[var(--color-line)] bg-white mt-4">
  <summary class="cursor-pointer px-4 py-3 font-medium text-[var(--color-ink)] flex items-center gap-2">
    Your bibliography <span data-bib-count class="text-xs bg-[var(--color-brand-soft)] text-[var(--color-brand)] rounded-full px-2 py-0.5">0</span>
  </summary>
  <div class="px-4 pb-4">
    <ol data-bib-list class="list-decimal ml-5 space-y-2 text-sm citation-output"></ol>
    <p data-bib-empty class="text-sm text-[var(--color-muted)]">No references yet. Generate a citation above and select Add to bibliography.</p>
    <div class="flex gap-2 mt-3">
      <button data-bib-copy type="button" class="text-sm bg-[var(--color-brand)] text-white px-3 py-1.5 rounded hover:bg-[var(--color-brand-dark)]">Copy all</button>
      <button data-bib-bibtex type="button" class="text-sm border border-[var(--color-brand)] text-[var(--color-brand)] px-3 py-1.5 rounded">Export BibTeX</button>
      <button data-bib-clear type="button" class="text-sm border border-[var(--color-line)] text-[var(--color-muted)] px-3 py-1.5 rounded ml-auto">Clear</button>
    </div>
  </div>
</details>

<script>
  import { initBibliographyPanel } from '../scripts/bibliography-panel.js';
  document.querySelectorAll('[data-bib-panel]').forEach((p) => initBibliographyPanel(p));
</script>
