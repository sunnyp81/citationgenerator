---
// Email capture for a per-style cheat-sheet PDF. Posts to the EmailIt worker (endpoint
// wired post-launch). magnet identifies which PDF to deliver.
interface Props { magnet: string; label?: string; }
const { magnet, label = 'Get the free citation cheat sheet' } = Astro.props;
---
<aside class="my-8 rounded-xl bg-[var(--color-ink)] text-white p-6">
  <h2 class="text-xl font-bold mb-1">{label}</h2>
  <p class="text-sm text-slate-300 mb-4">A one page quick reference you can keep beside your work. No spam, unsubscribe any time.</p>
  <form class="flex flex-wrap gap-2" data-optin action="https://emailit.sunnypatel.co.uk/subscribe" method="post">
    <input type="hidden" name="magnet" value={magnet} />
    <input type="email" name="email" required placeholder="you@university.edu"
      class="flex-1 min-w-[200px] rounded px-3 py-2 text-[var(--color-ink)] text-sm" />
    <button type="submit" class="bg-[var(--color-accent)] text-white px-4 py-2 rounded text-sm font-medium hover:opacity-90">Send it to me</button>
  </form>
</aside>
