---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AffiliateCTA from '../components/AffiliateCTA.astro';
import AdSlot from '../components/AdSlot.astro';
import OptinForm from '../components/OptinForm.astro';
import FAQ from '../components/FAQ.astro';

const title = 'Free Citation and Reference Tools - No Sign-up';
const description = 'Free tools for students and researchers: bibliography builder, in-text citation generator and BibTeX export, working across every citation style.';
const tools = [
  { name: 'Bibliography Builder', href: '/bibliography-builder', blurb: 'Collect references in any style and export your full bibliography or works cited list.' },
  { name: 'In-text Citation Generator', href: '/in-text-citation-generator', blurb: 'Generate just the in-text or parenthetical citation in any style.' },
];
const jsonld = [
  { '@context': 'https://schema.org', '@type': 'CollectionPage', name: 'Citation Tools', url: 'https://citationgenerator.store/tools' },
];
const faq = [
  { q: 'Are these tools free?', a: 'Yes, every tool is free with no account and no limit.' },
];
---
<Base title={title} description={description} jsonld={jsonld}>
  <div class="mx-auto max-w-3xl px-4 py-8">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Tools' }]} />
    <h1 class="text-3xl font-bold tracking-tight">Free citation tools</h1>
    <p class="text-lg text-[var(--color-muted)] mt-2 mb-6">Small, focused tools that work alongside the style generators.</p>
    <div class="grid sm:grid-cols-2 gap-3">
      {tools.map((t) => (
        <a href={t.href} class="block rounded-lg border border-[var(--color-line)] p-4 hover:border-[var(--color-brand)] hover:bg-[var(--color-brand-soft)]">
          <span class="font-semibold text-[var(--color-ink)]">{t.name}</span>
          <span class="block text-sm text-[var(--color-muted)] mt-1">{t.blurb}</span>
        </a>
      ))}
    </div>

    <AffiliateCTA variant="inline" />
    <AdSlot slot="mid-content" />
    <OptinForm magnet="citation-cheat-sheet" label="Get the free all-styles citation cheat sheet" />

    <FAQ items={faq} heading="About these tools" />
    <AdSlot slot="footer" />
  </div>
</Base>
