---
import Base from '../layouts/Base.astro';
import CitationTool from '../components/CitationTool.astro';
import BibliographyPanel from '../components/BibliographyPanel.astro';
import AffiliateCTA from '../components/AffiliateCTA.astro';
import AdSlot from '../components/AdSlot.astro';
import OptinForm from '../components/OptinForm.astro';
import FAQ from '../components/FAQ.astro';
import { styles, tier1Styles } from '../data/styles.js';

const title = 'Free Citation Generator - Every Style, Accurate, No Sign-up';
const description = 'Generate accurate citations and references in AMA, IEEE, ACS, Chicago, Harvard and more. Paste a DOI, ISBN or URL, copy the citation, build your bibliography. Free, no login.';
const jsonld = [
  {
    '@context': 'https://schema.org', '@type': 'WebSite',
    name: 'Citation Generator', url: 'https://citationgenerator.store',
  },
  {
    '@context': 'https://schema.org', '@type': 'SoftwareApplication',
    name: 'Citation Generator', applicationCategory: 'BrowserApplication', operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
];
const faq = [
  { q: 'Is this citation generator free?', a: 'Yes, every citation in every style is free with no account and no limit.' },
  { q: 'Which citation styles are supported?', a: 'AMA, IEEE, ACS, CSE, Turabian, Chicago, ASA, Bluebook, APSA, Harvard, APA, MLA and more, all built on the open Citation Style Language standard.' },
  { q: 'Do you store my data?', a: 'No. Your bibliography is saved only in your own browser. Nothing is sent to a server to generate a citation.' },
];
---
<Base title={title} description={description} jsonld={jsonld}>
  <section class="bg-[var(--color-brand-soft)] border-b border-[var(--color-line)]">
    <div class="mx-auto max-w-3xl px-4 py-12 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight">Free Citation Generator</h1>
      <p class="text-lg text-[var(--color-muted)] mt-3">Accurate references and in-text citations in every major style. Paste a DOI, ISBN or URL, or fill the form. No sign up.</p>
    </div>
  </section>

  <div class="mx-auto max-w-3xl px-4 py-8">
    <CitationTool defaultStyleId="ama" />
    <BibliographyPanel />

    <AdSlot slot="mid-content" />

    <h2 class="text-2xl font-bold mt-10 mb-4">Generate citations by style</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {styles.map((s) => (
        <a href={`/${s.slug}`} class="block rounded-lg border border-[var(--color-line)] p-4 hover:border-[var(--color-brand)] hover:bg-[var(--color-brand-soft)]">
          <span class="font-semibold text-[var(--color-ink)]">{s.labelLong}</span>
          <span class="block text-sm text-[var(--color-muted)] mt-1">{s.blurb}</span>
        </a>
      ))}
    </div>

    <OptinForm magnet="citation-cheat-sheet" label="Get the free all-styles citation cheat sheet" />
    <AffiliateCTA variant="post-citation" />

    <FAQ items={faq} />

    <AdSlot slot="footer" />
  </div>
</Base>
