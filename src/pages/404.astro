---
import Base from '../layouts/Base.astro';
import { styles } from '../data/styles.js';
---
<Base title="Page not found - Citation Generator" description="That page could not be found. Browse our free citation generators instead.">
  <div class="mx-auto max-w-2xl px-4 py-20 text-center">
    <h1 class="text-4xl font-bold">Page not found</h1>
    <p class="text-lg text-[var(--color-muted)] mt-3 mb-8">That page does not exist. Try a citation generator below.</p>
    <div class="flex flex-wrap gap-2 justify-center">
      {styles.slice(0, 8).map((s) => (
        <a href={`/${s.slug}`} class="text-sm rounded border border-[var(--color-line)] px-3 py-2 hover:border-[var(--color-brand)]">{s.label}</a>
      ))}
      <a href="/citation-generators" class="text-sm rounded bg-[var(--color-brand)] text-white px-3 py-2">All styles</a>
    </div>
  </div>
</Base>
